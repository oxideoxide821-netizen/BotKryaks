-- ==================== AURA LOGIC ====================
local auraActive = false
local auraConnection

local function startAura()
    auraActive = true
    auraButton.Text = "[] AURA: ON"
    auraButton.TextColor3 = STYLE.textActive
    statusDot.BackgroundColor3 = STYLE.dotOn
    mainFrame.BorderColor3 = STYLE.borderActive

    auraConnection = task.spawn(function()
        while auraActive do
            local slapEvent = game.ReplicatedStorage:FindFirstChild("GeneralHit", true) 
                or game.ReplicatedStorage:FindFirstChild("Slap", true)
                or game.ReplicatedStorage:FindFirstChild("Hit", true)

            if slapEvent then
                for _, player in pairs(Players:GetPlayers()) do
                    if not auraActive then break end
                    if player ~= LocalPlayer and not blacklist[player.UserId] 
                        and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid.Health > 0 then
                            slapEvent:FireServer(player.Character.HumanoidRootPart)
                            task.wait(0.01)
                        end
                    end
                end
            end
            task.wait(0.8)
        end
    end)
end

local function stopAura()
    auraActive = false
    auraButton.Text = "> AURA: OFF"
    auraButton.TextColor3 = STYLE.text
    statusDot.BackgroundColor3 = STYLE.dotOff
    mainFrame.BorderColor3 = STYLE.border
end

-- ==================== BUTTON ANIMATIONS ====================
local function buttonAnim(btn, downColor, downPos, upColor, upPos)
    btn.MouseButton1Down:Connect(function()
        btn.BackgroundColor3 = downColor
        btn.Position = downPos
    end)
    btn.MouseButton1Up:Connect(function()
        btn.BackgroundColor3 = upColor
        btn.Position = upPos
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = upColor
        btn.Position = upPos
    end)
end

