        currency_data[uid]["feed_count"] = 0
        currency_data[uid]["duel_wins"] = 0
        currency_data[uid]["robbery_success"] = 0
    return currency_data[uid]

def save_currency():
    safe_save_json(CURRENCY_FILE, currency_data)

