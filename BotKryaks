-- ==================== UTILITIES ====================
local function createShadow(parent, offset)
    local shadow = Instance.new("Frame")
    shadow.Name = "Shadow"
    shadow.Size = UDim2.new(1, 0, 1, 0)
    shadow.Position = UDim2.new(0, offset or 2, 0, offset or 2)
    shadow.BackgroundColor3 = STYLE.shadow
    shadow.BorderSizePixel = 0
    shadow.ZIndex = -1
    shadow.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = STYLE.corner
    corner.Parent = shadow
    return shadow
end

local function createCorner(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = radius or STYLE.corner
    corner.Parent = parent
    return corner
end

local function createBorder(parent, color, size)
    parent.BorderColor3 = color or STYLE.border
    parent.BorderSizePixel = size or 3
end

