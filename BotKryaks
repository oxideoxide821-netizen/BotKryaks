    food_type = food_type.lower()
    if food_type not in FOOD_TYPES and food_type != "кряксы":
        return False, "❌ Неизвестная валюта!"
    
    try:
        amount = int(amount)
        if amount < 1:
            return False, "❌ Сумма должна быть больше 0!"
