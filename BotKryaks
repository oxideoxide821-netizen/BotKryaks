def create_duel(challenger_id, target_id, bet):
    duel_id = f"{challenger_id}_{target_id}_{int(time.time())}"
    duels_data[duel_id] = {
        "challenger": str(challenger_id),
        "target": str(target_id),
        "bet": bet,
        "status": "pending",
        "created": datetime.now().isoformat()
    }
    safe_save_json(DUELS_FILE, duels_data)
    return duel_id

def accept_duel(duel_id):
    if duel_id not in duels_data:
        return False, "Дуэль не найдена"
    
    duel = duels_data[duel_id]
    if duel["status"] != "pending":
        return False, "Дуэль уже завершена"
    
    challenger = get_user_currency(int(duel["challenger"]))
    target = get_user_currency(int(duel["target"]))
    bet = duel["bet"]
    
    if challenger["кряксы"] < bet:
        return False, "У вызывающего недостаточно кряксов"
    if target["кряксы"] < bet:
        return False, "У вас недостаточно кряксов для принятия дуэли"
    
    challenger_roll = random.randint(1, 100)
    target_roll = random.randint(1, 100)
    
    challenger["кряксы"] -= bet
    target["кряксы"] -= bet
    
    winner_id = duel["challenger"] if challenger_roll > target_roll else duel["target"]
    winner = get_user_currency(int(winner_id))
    winner["кряксы"] += bet * 2
    winner["duel_wins"] = winner.get("duel_wins", 0) + 1
    
    check_achievement(int(winner_id), "duelist", winner["duel_wins"] >= 10)
    
    save_currency()
    
    duel["status"] = "completed"
    duel["challenger_roll"] = challenger_roll
    duel["target_roll"] = target_roll
    duel["winner"] = winner_id
    safe_save_json(DUELS_FILE, duels_data)
    
    result = f"⚔️ Результат дуэли:\n"
    result += f"Бросок вызывающего: {challenger_roll}\n"
    result += f"Ваш бросок: {target_roll}\n"
    result += f"Победитель: {'Вы' if winner_id == duel['target'] else 'Противник'}\n"
    result += f"Выигрыш: {bet * 2} кряксов"
    
    return True, result

# --- СИСТЕМА ОГРАБЛЕНИЙ ---
def rob_user(robber_id, target_id):
    if not can_rob(robber_id):
        last_time = datetime.fromisoformat(robbery_cooldown[str(robber_id)])
        remaining = (last_time + timedelta(hours=3)) - datetime.now()
        minutes = int(remaining.total_seconds() / 60)
        return None, f"⏳ Уже грабил! Жди еще {minutes} мин"
    
    robber = get_user_currency(robber_id)
    target = get_user_currency(target_id)
    
    if target["кряксы"] < 10:
        return None, "❌ У жертвы слишком мало кряксов для ограбления"
    
    success_chance = 40
    roll = random.randint(1, 100)
    
    set_rob_cooldown(robber_id)
    
    if roll <= success_chance:
        stolen = min(random.randint(5, 20), target["кряксы"])
        target["кряксы"] -= stolen
        robber["кряксы"] += stolen
        robber["robbery_success"] = robber.get("robbery_success", 0) + 1
        
        check_achievement(robber_id, "thief", robber["robbery_success"] >= 5)
        save_currency()
        
        return stolen, f"🦹 Успешное ограбление! Украдено {stolen} кряксов"
    else:
        fine = min(10, robber["кряксы"])
        robber["кряксы"] -= fine
        save_currency()
        return 0, f"🚔 Провал! Тебя поймали и оштрафовали на {fine} кряксов"

