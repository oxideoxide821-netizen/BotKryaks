def extract_emojis(text):
    try:
        emoji_pattern = re.compile("["
            u"\U0001F600-\U0001F64F"
            u"\U0001F300-\U0001F5FF"
            u"\U0001F680-\U0001F6FF"
            u"\U0001F1E0-\U0001F1FF"
            u"\U00002702-\U000027B0"
            u"\U000024C2-\U0001F251"
            "]+", flags=re.UNICODE)
        return emoji_pattern.findall(text)
    except:
        return []

def get_chat_mode(chat_id: int) -> str:
    return chat_modes.get(str(chat_id), "global")

def set_chat_mode(chat_id: int, mode: str):
    chat_modes[str(chat_id)] = mode
    safe_save_json(CHAT_MODES_FILE, chat_modes)

def get_chat_db_file(chat_id: int) -> str:
    mode = get_chat_mode(chat_id)
    if mode == "local":
        return f"brain_{chat_id}.txt"
    return DB_FILE

def safe_save_to_brain_chat(text, chat_id):
    try:
        if text and not text.startswith('/') and len(text) > 0:
            if "http" in text:
                return
            emojis = extract_emojis(text)
            if emojis:
                for emoji in emojis:
                    if emoji not in emoji_brain:
                        emoji_brain.append(emoji)
                        if len(emoji_brain) > 1000:
                            emoji_brain.pop(0)
                safe_save_json(EMOJI_FILE, emoji_brain)

            db_path = get_chat_db_file(chat_id)

            lines = []
            if os.path.exists(db_path):
                with open(db_path, "r", encoding="utf-8", errors='ignore') as f:
                    lines = f.readlines()
            lines.append(text.replace('\n', ' ').strip() + "\n")
            lines = lines[-20000:]
            with open(db_path, "w", encoding="utf-8") as f:
                f.writelines(lines)
    except Exception as e:
        logging.error(f"Ошибка сохранения в мозг: {e}")

def safe_get_text_answer():
    try:
        if not os.path.exists(DB_FILE) or os.stat(DB_FILE).st_size < 100:
            return "Мало данных... Навалите контента!"
        with open(DB_FILE, "r", encoding="utf-8", errors='ignore') as f:
            data = f.read()
        model = markovify.NewlineText(data, state_size=2)
        ans = model.make_sentence(tries=150)
        if not ans:
            lines = data.splitlines()
            ans = random.choice(lines) if lines else "Кря!"
        if random.random() < 0.4 and emoji_brain:
            ans = random.choice(emoji_brain) + " " + ans
