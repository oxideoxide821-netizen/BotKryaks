def safe_can_use_bonus(user_id):
    try:
        now = datetime.now()
        last_time = bonus_time.get(str(user_id))
        if not last_time:
            return True
        last = datetime.fromisoformat(last_time)
        diff = now - last
        return diff >= timedelta(hours=23)
    except:
        return True

