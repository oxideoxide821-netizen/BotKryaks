def safe_get_random_words_from_brain(count=4):
    try:
        if not os.path.exists(DB_FILE) or os.stat(DB_FILE).st_size < 100:
            return ["Крякс", "Сглыпа", "Админ", "Болото"]
        with open(DB_FILE, "r", encoding="utf-8", errors='ignore') as f:
            data = f.read()
        words = data.split()
        good_words = [w.strip(".,!?;:") for w in words if len(w) > 3]
        if len(good_words) < count:
            return ["Крякс", "Сглыпа", "Админ", "Болото"]
        return random.sample(good_words, count)
    except:
        return ["Крякс", "Сглыпа", "Админ", "Болото"]

