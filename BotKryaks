-- ==================== DRAGGING ====================
local dragging = false
local dragStart, startPos

local function makeDraggable(frame, handle)
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
end

makeDraggable(mainFrame, dragHandle)
makeDraggable(listToggleFrame, listToggleBtn)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
        listToggleFrame.Position = UDim2.new(
            0, mainFrame.Position.X.Offset + 225,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
        listPanel.Position = UDim2.new(
            0, mainFrame.Position.X.Offset,
            0.5, (startPos.Y.Offset + delta.Y) + 35
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- ==================== BLACKLIST LOGIC ====================
local blacklist = {} -- [UserId] = true (if true - do not slap)

local function updateBlacklistUI()
    -- Clear existing entries
    for _, entry in pairs(scrollFrame:GetChildren()) do
        if entry:IsA("Frame") then
            entry:Destroy()
        end
    end

    local yOffset = 0
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local entry = Instance.new("Frame")
            entry.Name = "Entry_" .. player.Name
            entry.Size = UDim2.new(1, -4, 0, 28)
            entry.Position = UDim2.new(0, 2, 0, yOffset)
            entry.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            entry.BorderColor3 = Color3.fromRGB(100, 0, 0)
            entry.BorderSizePixel = 1
            entry.Parent = scrollFrame

            createCorner(entry, STYLE.cornerSmall)

            -- Checkbox
            local checkbox = Instance.new("TextButton")
            checkbox.Name = "Checkbox"
            checkbox.Size = UDim2.new(0, 18, 0, 18)
            checkbox.Position = UDim2.new(0, 5, 0.5, -9)
            checkbox.BackgroundColor3 = blacklist[player.UserId] and STYLE.checkOn or STYLE.checkOff
            checkbox.BorderColor3 = STYLE.accent
            checkbox.BorderSizePixel = 2
            checkbox.Text = blacklist[player.UserId] and "X" or ""
            checkbox.TextColor3 = Color3.fromRGB(255, 255, 255)
            checkbox.TextSize = 14
            checkbox.Font = STYLE.fontBold
            checkbox.Parent = entry

            createCorner(checkbox, UDim.new(0, 1))

            -- Player name
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Name = "NameLabel"
            nameLabel.Size = UDim2.new(1, -30, 1, 0)
            nameLabel.Position = UDim2.new(0, 28, 0, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = " " .. player.Name
            nameLabel.TextColor3 = blacklist[player.UserId] and Color3.fromRGB(150, 150, 150) or STYLE.text
            nameLabel.TextSize = 13
            nameLabel.Font = STYLE.font
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = entry

            -- Hover effect
            entry.MouseEnter:Connect(function()
                if not blacklist[player.UserId] then
                    entry.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                end
            end)

            entry.MouseLeave:Connect(function()
                if not blacklist[player.UserId] then
                    entry.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
                end
            end)

            -- Click on checkbox - FIXED: use direct player reference
            checkbox.MouseButton1Click:Connect(function()
                local isBlacklisted = not blacklist[player.UserId]
                blacklist[player.UserId] = isBlacklisted

                checkbox.BackgroundColor3 = isBlacklisted and STYLE.checkOn or STYLE.checkOff
                checkbox.Text = isBlacklisted and "X" or ""
                nameLabel.TextColor3 = isBlacklisted and Color3.fromRGB(150, 150, 150) or STYLE.text
                entry.BackgroundColor3 = isBlacklisted and Color3.fromRGB(20, 40, 20) or Color3.fromRGB(25, 25, 25)
            end)

            yOffset = yOffset + 32
        end
    end

    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(yOffset, 1))
end

