@bot.message_handler(content_types=['text'])
def text_handler(message):
    try:
        if message.date < int(time.time()) - 300:
            return
        if message.text.startswith('/'): return
        if message.chat.type == "private": return
       
        uid = str(message.from_user.id)
        text = message.text
        text_lower = text.lower()

        if random.random() < 0.15:
            safe_set_reaction(message.chat.id, message.message_id, random.choice(REACTIONS))

        for trigger, replies in TRIGGER_PHRASES.items():
            if trigger in text_lower:
                safe_send_or_reply(message, random.choice(replies))
                return

        if message.reply_to_message and text in ['+', '-', '👍', '👎']:
            target_id = str(message.reply_to_message.from_user.id)
            if target_id == uid:
                bot.send_message(message.chat.id, "Самолайк — путь в никуда.")
                return
            if not safe_can_use_bonus(uid):
                bot.send_message(message.chat.id, "⏳ Ты уже ставил репутацию! Жди 23 часа.")
                return
            reputation[target_id] = reputation.get(target_id, 0) + (1 if text in ['+', '👍'] else -1)
            safe_save_json(REP_FILE, reputation)
            safe_save_bonus_time(uid)
            
            check_achievement(int(target_id), "popular", reputation[target_id] >= 50)
            
            bot.send_message(message.chat.id, f"✅ Репутация изменена! (Всего: {reputation[target_id]})")
            return

        safe_save_to_brain_chat(text, message.chat.id)
        
        if message.from_user.id == bot.get_me().id:
            return
        
        is_reply_to_bot = message.reply_to_message and message.reply_to_message.from_user.id == bot.get_me().id
        is_call = "крякс" in text_lower
        
        should_answer = is_reply_to_bot or is_call or random.random() < 0.5
        
        if should_answer:
            roll = random.random()
            if roll < 0.85 or not media_brain["stickers"]:
                safe_send_or_reply(message, safe_get_text_answer_chat(message.chat.id))
            elif roll < 0.95:
                if random.random() < 0.3:
                    bot.reply_to(message, "🦆")
                else:
                    bot.send_sticker(message.chat.id, random.choice(media_brain["stickers"]))
            else:
                if media_brain["animations"]:
                    if random.random() < 0.3:
                        bot.reply_to(message, "🦆")
                    else:
                        bot.send_animation(message.chat.id, random.choice(media_brain["animations"]))
                else:
                    safe_send_or_reply(message, safe_get_text_answer_chat(message.chat.id))
        
        if random.random() < 0.03:
            safe_send_random_poll(message.chat.id)
    except Exception as e:
        logging.error(f"Ошибка текста: {traceback.format_exc()}")

